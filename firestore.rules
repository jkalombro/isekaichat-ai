rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - createdAt: timestamp
    //
    // Collection: characters
    // Document ID: {characterId}
    // Fields:
    //   - ownerId: string (required) - UID of the creator
    //   - name: string (required)
    //   - source: string (required)
    //   - profile: string (required)
    //   - avatarUrl: string (optional)
    //   - totalTokensConsumed: number (optional)
    //   - lastCalculationDatetime: timestamp (optional)
    //   - createdAt: timestamp
    //
    // Collection: characters/{characterId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - chatId: string (required)
    //   - sender: string (required, 'user' or 'character')
    //   - text: string (required)
    //   - tokensConsumed: number (optional)
    //   - timestamp: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isCharOwner(charData) {
      return isAuthenticated() && request.auth.uid == charData.ownerId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 256 &&
             (!('geminiKey' in data) || data.geminiKey == null || (data.geminiKey is string && data.geminiKey.size() < 200));
    }

    function isValidCharacter(data) {
      return data.keys().hasAll(['ownerId', 'name', 'source', 'profile']) &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.source is string && data.source.size() > 0 && data.source.size() < 100 &&
             data.profile is string && data.profile.size() > 0 && data.profile.size() < 5000 &&
             (!('avatarUrl' in data) || data.avatarUrl == null || (data.avatarUrl is string && data.avatarUrl.size() < 1000)) &&
             (!('totalTokensConsumed' in data) || data.totalTokensConsumed is number) &&
             (!('lastCalculationDatetime' in data) || data.lastCalculationDatetime is timestamp);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'sender', 'text', 'timestamp']) &&
             data.sender in ['user', 'character'] &&
             data.text is string && data.text.size() > 0 && data.text.size() < 5000 &&
             (!('tokensConsumed' in data) || data.tokensConsumed is number);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "jkninja238@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAuthenticated(); // Required for Rift Key uniqueness check
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid;
    }

    match /characters/{characterId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCharacter(request.resource.data);
      allow update: if (isCharOwner(resource.data) || isAdmin() || 
                       (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avatarUrl', 'totalTokensConsumed', 'lastCalculationDatetime']))) && 
                    isValidCharacter(request.resource.data) &&
                    request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isCharOwner(resource.data) || isAdmin();

      match /messages/{messageId} {
        allow read: if isCharOwner(get(/databases/$(database)/documents/characters/$(characterId)).data) || isAdmin();
        allow create: if isCharOwner(get(/databases/$(database)/documents/characters/$(characterId)).data) && isValidMessage(request.resource.data);
        allow delete: if isCharOwner(get(/databases/$(database)/documents/characters/$(characterId)).data) || isAdmin();
      }
    }
  }
}
