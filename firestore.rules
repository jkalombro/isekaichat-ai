rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isCharOwner(charData) {
      return isAuthenticated() && request.auth.uid == charData.ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() < 256 &&
             (!('geminiKey' in data) || data.geminiKey == null || (data.geminiKey is string && data.geminiKey.size() < 200));
    }

    function isValidCharacter(data) {
      return data.keys().hasAll(['ownerId', 'name', 'source', 'profile']) &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.source is string && data.source.size() > 0 && data.source.size() <= 100 &&
             data.profile is string && data.profile.size() > 0 && data.profile.size() <= 15000 &&
             (!('avatarUrl' in data) || data.avatarUrl == null || (data.avatarUrl is string && data.avatarUrl.size() <= 1000)) &&
             (!('totalTokensConsumed' in data) || data.totalTokensConsumed is number) &&
             (!('lastCalculationDatetime' in data) || data.lastCalculationDatetime == null || data.lastCalculationDatetime is timestamp || data.lastCalculationDatetime == request.time) &&
             (!('memories' in data) || data.memories == null || data.memories is string) &&
             (!('lastSummarizedIndex' in data) || data.lastSummarizedIndex is number) &&
             (!('createdAt' in data) || data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidSummaryToken(data) {
      return data.keys().hasAll(['tokensConsumed', 'dateTimeSummarized']) &&
             data.tokensConsumed is number &&
             (data.dateTimeSummarized is timestamp || data.dateTimeSummarized == request.time);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'sender', 'text', 'timestamp']) &&
             data.sender in ['user', 'character'] &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 10000 &&
             data.chatId is string &&
             (data.timestamp is timestamp || data.timestamp == request.time) &&
             (!('tokensConsumed' in data) || data.tokensConsumed is number) &&
             (!('isEdited' in data) || data.isEdited is bool);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "jkninja238@gmail.com" && request.auth.token.email_verified == true ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isHardcodedAdmin() {
      return isAuthenticated() &&
        request.auth.token.email == "jkninja238@gmail.com" &&
        request.auth.token.email_verified == true;
    }

    function isValidAppStatus(data) {
      return data.keys().hasAll(['isMaintenanceMode']) &&
             data.isMaintenanceMode is bool &&
             (!('maintenanceStartDateTime' in data) || data.maintenanceStartDateTime == null || data.maintenanceStartDateTime is timestamp) &&
             (!('maintenanceEndDateTime' in data) || data.maintenanceEndDateTime == null || data.maintenanceEndDateTime is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /appstatus/{statusId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(statusId) && isValidAppStatus(request.resource.data);
    }

    match /users/{userId} {
      allow get: if (isOwner(userId) || isAdmin()) && isValidId(userId);
      allow list: if isAuthenticated() && (resource.data.uid == request.auth.uid || isHardcodedAdmin());
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid;
    }

    match /characters/{characterId} {
      allow get: if isAuthenticated() && isValidId(characterId);
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidId(characterId) && isValidCharacter(request.resource.data);
      allow update: if (isCharOwner(resource.data) || isAdmin()) && 
                    isValidId(characterId) &&
                    isValidCharacter(request.resource.data) &&
                    request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if (isCharOwner(resource.data) || isAdmin()) && isValidId(characterId);

      match /messages/{messageId} {
        allow get: if (isCharOwner(get(/databases/$(database)/documents/characters/$(characterId)).data) || isAdmin()) && isValidId(messageId);
        allow list: if isCharOwner(get(/databases/$(database)/documents/characters/$(characterId)).data) || isAdmin();
        allow create: if (isCharOwner(get(/databases/$(database)/documents/characters/$(characterId)).data) || isAdmin()) && isValidId(messageId) && isValidMessage(request.resource.data);
        allow update: if (isCharOwner(get(/databases/$(database)/documents/characters/$(characterId)).data) || isAdmin()) && 
                      isValidId(messageId) &&
                      isValidMessage(request.resource.data) && 
                      (resource.data.sender == 'user' || isAdmin());
        allow delete: if (isCharOwner(get(/databases/$(database)/documents/characters/$(characterId)).data) || isAdmin()) && isValidId(messageId);
      }

      match /summarytokens/{tokenId} {
        allow get: if (isCharOwner(get(/databases/$(database)/documents/characters/$(characterId)).data) || isAdmin()) && isValidId(tokenId);
        allow list: if isCharOwner(get(/databases/$(database)/documents/characters/$(characterId)).data) || isAdmin();
        allow create: if (isCharOwner(get(/databases/$(database)/documents/characters/$(characterId)).data) || isAdmin()) && isValidId(tokenId) && isValidSummaryToken(request.resource.data);
      }
    }
  }
}
