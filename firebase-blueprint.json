{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "geminiKey": { "type": "string", "default": null },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Character": {
      "title": "Character",
      "description": "A fictional character created by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "source": { "type": "string" },
        "profile": { "type": "string", "description": "The harvested personality profile from Gemini" },
        "avatarUrl": { "type": "string" },
        "totalTokensConsumed": { "type": "integer", "default": 0 },
        "lastCalculationDatetime": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "source", "profile"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "character"] },
        "text": { "type": "string" },
        "tokensConsumed": { "type": "integer", "default": 0 },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "sender", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User private data"
    },
    "/characters/{characterId}": {
      "schema": "Character",
      "description": "Characters created by users"
    },
    "/characters/{characterId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat history for a character"
    }
  }
}
